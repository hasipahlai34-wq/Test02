# Adaptive RAG 环境变量模板
# 复制为 .env 后填写你自己的服务凭据。不要把 .env 提交到 GitHub。

# ---------------------------------------------------------------------
# LLM：任意 OpenAI 兼容的聊天模型服务
# ---------------------------------------------------------------------
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1

LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_SIMPLE_MODEL=gpt-4o-mini
LLM_MEDIUM_MODEL=gpt-4o-mini
LLM_COMPLEX_MODEL=gpt-4o

LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120
LLM_MAX_RETRIES=2

# 可选：安全检查专用模型；不设置时复用默认 LLM。
SAFETY_MODEL=
SAFETY_BASE_URL=
SAFETY_API_KEY=

# ---------------------------------------------------------------------
# 向量模型配置
# ---------------------------------------------------------------------
# 国内中英文混合 RAG 推荐：通过 DashScope 的 OpenAI 兼容接口地址使用 text-embedding-v4。
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
# DashScope text-embedding-v4 单次请求最多支持 10 条文本。
EMBEDDING_BATCH_SIZE=10

# 可选：受限网络下的 Hugging Face 下载镜像。
HF_ENDPOINT=https://hf-mirror.com

# 仅当 EMBEDDING_PROVIDER=openai 时需要。
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
# 可选：DashScope 共享密钥。设置后可同时用于向量化（embedding）和重排（rerank）。
DASHSCOPE_API_KEY=

# ---------------------------------------------------------------------
# 重排模型配置
# ---------------------------------------------------------------------
RERANK_ENABLED=true
RERANK_PROVIDER=dashscope
RERANK_MODEL=qwen3-rerank
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1/reranks
RERANK_API_KEY=
RERANK_CANDIDATE_TOP_K=20
RERANK_TOP_K=6
RERANK_THRESHOLD=0.0
RERANK_INSTRUCT=根据检索查询召回能够回答问题的相关段落。
RERANK_TIMEOUT=30

# ---------------------------------------------------------------------
# 向量库与检索参数
# ---------------------------------------------------------------------
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=adaptive_rag_docs_v4_1024

RETRIEVAL_TOP_K=10
RETRIEVAL_THRESHOLD=0.0
BM25_TOP_K=10
DENSE_TOP_K=40

# ---------------------------------------------------------------------
# 文档分块与上下文窗口管理
# ---------------------------------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=100
CHUNK_MIN_SIZE=100
CHUNK_STRUCTURE_AWARE=true
CHUNK_HEADING_FONT_DELTA=2

CONTEXT_MAX_TOKENS=8000
CONTEXT_COMPRESS_THRESHOLD=0.5

# ---------------------------------------------------------------------
# 熔断器配置
# ---------------------------------------------------------------------
CB_QUALITY_WINDOW_SIZE=20
CB_QUALITY_FAILURE_THRESHOLD=0.3
CB_QUALITY_TIMEOUT_SECONDS=60
CB_FREQ_MAX_REQUESTS=20
CB_FREQ_REFILL_RATE=20

# ---------------------------------------------------------------------
# 记忆与 HITL 数据目录
# ---------------------------------------------------------------------
MEMORY_SHORT_TERM_MAX_ROUNDS=10
MEMORY_MEDIUM_TERM_DB=./data/sqlite/memory.db
LTM_CHROMA_DIR=./data/ltm_chroma

HITL_ENABLED=true
HITL_INTERRUPT_TIMEOUT_SECONDS=1800
HITL_QUEUE_DIR=./data/hitl_queue
HITL_RESULTS_DIR=./data/hitl_results

# ---------------------------------------------------------------------
# RAGAS 在线评估
# ---------------------------------------------------------------------
# 默认关闭，避免新部署在没有评估模型 key 时阻塞演示。需要线上评估时改为 true。
RAGAS_ONLINE_ENABLED=false
RAGAS_FAITHFULNESS_THRESHOLD=0.6
RAGAS_RELEVANCY_THRESHOLD=0.5
RAGAS_CONTEXT_PRECISION_THRESHOLD=0.5
RAGAS_EVAL_MODEL=deepseek-v4-pro
RAGAS_EVAL_BASE_URL=https://api.deepseek.com/v1
RAGAS_EVAL_API_KEY=

# 可选：LangSmith 追踪
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=adaptive-rag
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# 可选：Langfuse 追踪。需要在 Langfuse 项目设置中复制公钥和密钥。
LANGFUSE_ENABLED=false
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------
# 优化开关
# ---------------------------------------------------------------------
OPT_CLASSIFY_RULES_EXPANDED=true
OPT_INPUT_SAFETY_PRESCREEN=true
OPT_OUTPUT_SAFETY_DOMAIN_SKIP=true
OPT_REVIEW_FAST_PATH=true
OPT_SUFFICIENCY_HEURISTIC=true

# ---------------------------------------------------------------------
# 应用配置
# ---------------------------------------------------------------------
DEFAULT_LANGUAGE=中文
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

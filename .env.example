# Adaptive RAG environment template
# Copy this file to .env and fill in your own credentials.

# ---------------------------------------------------------------------
# LLM: any OpenAI-compatible chat completion provider
# ---------------------------------------------------------------------
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1

LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_SIMPLE_MODEL=gpt-4o-mini
LLM_MEDIUM_MODEL=gpt-4o-mini
LLM_COMPLEX_MODEL=gpt-4o

LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120
LLM_MAX_RETRIES=2

# Optional: model used by safety checks. Defaults to LLM_DEFAULT_MODEL.
# SAFETY_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------
# Embeddings
# ---------------------------------------------------------------------
# local: sentence-transformers, no API key required after first download
# openai: OpenAI-compatible embedding endpoint
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSIONS=1536

# Optional mirror for Hugging Face downloads in restricted networks.
# HF_ENDPOINT=https://hf-mirror.com

# Only needed when EMBEDDING_PROVIDER=openai.
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=

# ---------------------------------------------------------------------
# Reranker
# ---------------------------------------------------------------------
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_K=5
RERANK_THRESHOLD=0.3

# ---------------------------------------------------------------------
# Vector store and retrieval
# ---------------------------------------------------------------------
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=adaptive_rag_docs

RETRIEVAL_TOP_K=10
RETRIEVAL_THRESHOLD=0.5
BM25_TOP_K=5

# ---------------------------------------------------------------------
# Context management
# ---------------------------------------------------------------------
CONTEXT_MAX_TOKENS=8000
CONTEXT_COMPRESS_THRESHOLD=0.5

# ---------------------------------------------------------------------
# Circuit breakers
# ---------------------------------------------------------------------
CB_QUALITY_WINDOW_SIZE=20
CB_QUALITY_FAILURE_THRESHOLD=0.3
CB_QUALITY_TIMEOUT_SECONDS=60
CB_FREQ_MAX_REQUESTS=20
CB_FREQ_REFILL_RATE=20

# ---------------------------------------------------------------------
# Memory and HITL data
# ---------------------------------------------------------------------
MEMORY_SHORT_TERM_MAX_ROUNDS=10
MEMORY_MEDIUM_TERM_DB=./data/sqlite/memory.db
LTM_CHROMA_DIR=./data/ltm_chroma

HITL_ENABLED=true
HITL_INTERRUPT_TIMEOUT_SECONDS=1800
HITL_QUEUE_DIR=./data/hitl_queue
HITL_RESULTS_DIR=./data/hitl_results

# ---------------------------------------------------------------------
# RAGAS online evaluation
# ---------------------------------------------------------------------
RAGAS_ONLINE_ENABLED=true
RAGAS_FAITHFULNESS_THRESHOLD=0.6
RAGAS_RELEVANCY_THRESHOLD=0.5
RAGAS_CONTEXT_PRECISION_THRESHOLD=0.5
RAGAS_EVAL_MODEL=deepseek-v4-pro
RAGAS_EVAL_BASE_URL=https://api.deepseek.com/v1
RAGAS_EVAL_API_KEY=

# Optional LangSmith tracing
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=adaptive-rag
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ---------------------------------------------------------------------
# App
# ---------------------------------------------------------------------
DEFAULT_LANGUAGE=中文
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
